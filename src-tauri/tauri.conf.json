{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PayrollPro",
  "version": "0.1.0",
  "identifier": "ai.tigercfo.payrollpro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "PayrollPro",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "dmg"],
    "icon": []
  }
}
